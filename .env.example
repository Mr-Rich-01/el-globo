# ============================================
# EL GLOBO — Environment Variables
# Copiar para .env e preencher os valores
# ============================================

# App
NODE_ENV=production
APP_URL=https://elglobo.rssystems.tech
APP_NAME="EL Globo"

# Database
# Em produção o docker-compose.yml monta o DATABASE_URL automaticamente
# a partir do DB_PASSWORD (host interno: elglobo-db)
DATABASE_URL=postgresql://elglobo:CHANGE_ME_STRONG_PASSWORD@elglobo-db:5432/elglobodb
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE
JWT_EXPIRY=8h

# Feature Flags
ENABLE_THERMAL_PRINT=false
THERMAL_PRINTER_IP=192.168.1.100
THERMAL_PRINTER_PORT=9100
